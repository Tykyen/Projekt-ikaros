# Dependencies
node_modules/

# Build output
dist/

# ML model cache / runtime data (~1.5 GB, stahuje/generuje se; nepatří do gitu)
backend/data/

# Nahrané soubory uživatelů (runtime; nepatří do gitu)
backend/uploads/

# Environment
.env
.env.local

# Coverage
coverage/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude local settings
.claude/settings.local.json

# Git worktrees — pracovní kopie, do repa nepatří.
# `.claude/worktrees/` zakládá Claude Code (izolované agentí worktrees); bez tohoto
# pravidla je `git add .` zachytí jako gitlink (mode 160000) a repo si nese odkaz
# na commit smazané větve. Odstraněno 2026-07-20 v R3 24.5.
.worktrees/
.claude/worktrees/

# Parity check output
backend/scripts/parity-check/output/*.json

# Husky internals (regenerated by `npm install`)
backend/.husky/_/
