{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": ["node_modules/(?!(uuid|meilisearch)/)"],
  "moduleNameMapper": {
    "^archiver$": "<rootDir>/mocks/archiver.stub.ts"
  },
  "maxWorkers": 1,
  "testTimeout": 120000
}
