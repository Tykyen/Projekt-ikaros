# ── Server ──
PORT=3000
NODE_ENV=development
# Produkční FE URL (CORS, WS origin, odkazy v mailech). V produkci POVINNÉ (env.validation).
FRONTEND_URL=http://localhost:5173
# Veřejná BE URL (disk-fallback obrázky). V produkci POVINNÉ.
BACKEND_BASE_URL=http://localhost:3000

# ── Databáze ──
MONGODB_URI=mongodb://localhost:27017/ikaros

# ── JWT ──
JWT_SECRET=change-this-secret-in-production
# Access token TTL (krátký — refresh token rotace drží session). Default 1d.
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-this-different-secret-in-production
# Refresh token TTL = doba do odhlášení při NEČINNOSTI (sliding okno se obnoví
# při každém /auth/refresh). 60 = řídce používaný mobil zůstane přihlášený.
JWT_REFRESH_TTL_DAYS=60
# 15.8 — TTL guest tokenu pro anonymní Putyku (host bez registrace). Formát je
# zápis knihovny `ms` ('14d', '48h'). Default v kódu je 14d; tady je hodnota
# uvedená explicitně, aby bylo vidět, že se dá ladit bez zásahu do zdrojáku.
ANON_SESSION_TTL=14d

# ── 2FA TOTP (14.1) ──
# Šifrovací klíč pro TOTP secrety v DB. 2FA je opt-in → bez klíče je setup
# fail-closed (503), ne boot-fatal. V prod nastav přes GitHub secret TOTP_ENC_KEY.
# Generuj např.: openssl rand -base64 32
TOTP_ENC_KEY=

# ── Captcha (Cloudflare Turnstile) ──
# Dev test keys (vždy projdou). V produkci vygeneruj reálné v Cloudflare dashboardu.
# Bez TURNSTILE_SECRET je captcha v produkci fail-closed (registrace selže).
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# ── Storage (Cloudinary) ──
# Formát: cloudinary://API_KEY:API_SECRET@CLOUD_NAME. Bez něj běží disk fallback (/static/).
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=

# ── Search (Meilisearch) ──
MEILI_HOST=http://localhost:7700
# V produkci = MEILI_MASTER_KEY (min. 16 bytů). Bez něj search bez auth.
MEILI_API_KEY=

# ── Cache / WebSocket scale (Redis) ──
REDIS_URL=redis://localhost:6379
# "1" = multi-instance Socket.IO přes Redis adapter; jinak in-memory (single instance).
SOCKET_IO_REDIS=
# "1" = rate-limit counter ve sdíleném Redis (multi-instance); jinak in-memory (D-028).
# Zapni až při 2+ replikách backendu. Bez dostupného Redisu → fallback in-memory + warn.
THROTTLER_REDIS=

# ── Web push (VAPID) ──
# Vygeneruj: npx web-push generate-vapid-keys. Bez nich push nefunguje (app běží).
VAPID_SUBJECT=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── SMTP (transakční maily — reset hesla, ověření emailu) ──
# Když nejsou SMTP_HOST + SMTP_USER nastaveny, mailer jen loguje (dev).
# Gmail: SMTP_PASS = App Password (ne běžné heslo).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Projekt Ikaros <tyky.projekt.ikaros@gmail.com>
# Denní strop odeslaných mailů (mail outbox) — rezerva pod Gmail limit ~500/den.
# Po dosažení odchází UŽ JEN vysoká priorita (reset hesla), zbytek počká na další den.
SMTP_DAILY_CAP=400

# ── Mazání účtu (soft-delete recovery okno, dny) ──
DELETION_HOLD_DAYS=30

# ── Embedding / sémantické vyhledávání (volitelné, mají defaulty) ──
EMBEDDING_GRANITE107_ENABLED=true
EMBEDDING_GRANITE278_ENABLED=true
# Model URL (ONNX + tokenizer). Default míří na externí osobní web (www.patrikzplzne.cz)
# → pro ostrý provoz přesměruj na vlastní hosting (jinak search závisí na cizí doméně).
EMBEDDING_GRANITE107_ONNX_URL=https://www.patrikzplzne.cz/data/matrix_embedding_models/onnx_granite_107/model.onnx
EMBEDDING_GRANITE107_TOKENIZER_URL=https://www.patrikzplzne.cz/data/matrix_embedding_models/onnx_granite_107/sentencepiece.bpe.model
EMBEDDING_GRANITE278_ONNX_URL=https://www.patrikzplzne.cz/data/matrix_embedding_models/onnx_granite_278/model.onnx
EMBEDDING_GRANITE278_TOKENIZER_URL=https://www.patrikzplzne.cz/data/matrix_embedding_models/onnx_granite_278/sentencepiece.bpe.model
